#!/usr/bin/env bash
set -euo pipefail

# Source common configuration
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/../shared"

print_sandbox_dir

GROUP_ID="$(id -g)"
USER_ID="$(id -u)"
# Generate a 48-character random hexadecimal password from /dev/urandom (od reads 24 bytes, converts to 48 hex chars)
OPENCODE_PASSWORD="$(od -An -tx1 -N24 /dev/urandom | tr -d ' \n')"

umask u=rwx,go=
mkdir -p "${OPENCODE_SANDBOX_DIR}"
chmod u=rwx,go= "${OPENCODE_SANDBOX_DIR}"

mkdir -p "${OPENCODE_STATE_DIR}"
chmod u=rwx,go= "${OPENCODE_STATE_DIR}"

printf '%s\n' "${SANDBOX_NAME}" > "${CONTAINER_NAME_FILE}"
echo "Container name: ${SANDBOX_NAME}"

printf '%s\n' "${OPENCODE_PASSWORD}" > "${OPENCODE_PASSWORD_FILE}"
chmod u=rw,go= "${OPENCODE_PASSWORD_FILE}"
echo "Generated OpenCode password and saved it to ${OPENCODE_PASSWORD_FILE}"

echo "Copying MISE config from ${MISE_CONFIG_ROOT_FILE} ..."
cp "${MISE_CONFIG_ROOT_FILE}" "${MISE_CONFIG_SANDBOX_FILE}"

echo "Copying entrypoint script ..."
cp "${SANDBOX_HOME}/entrypoint.sh" "${OPENCODE_SANDBOX_DIR}/entrypoint.sh"

echo "Copying squid configuration ..."
cp "${SANDBOX_HOME}/squid.conf" "${OPENCODE_SANDBOX_DIR}/squid.conf"

echo "Processing sandbox configuration ..."
if [[ -f "${CONFIG_FILE}" ]]; then
  SQUID_WHITELIST="${OPENCODE_SANDBOX_DIR}/squid-whitelist.txt"
  HOST_PORTS="${OPENCODE_SANDBOX_DIR}/host-ports.txt"
  ENV_PASSTHROUGH="${OPENCODE_SANDBOX_DIR}/env-passthrough.txt"
  ENV_STATIC="${OPENCODE_SANDBOX_DIR}/env.txt"
  true > "${SQUID_WHITELIST}"
  true > "${HOST_PORTS}"
  true > "${ENV_PASSTHROUGH}"
  true > "${ENV_STATIC}"
  section=""
  while IFS= read -r line || [[ -n "${line}" ]]; do
    # Skip blank lines and comment lines (trimmed)
    trimmed="${line#"${line%%[![:space:]]*}"}"
    [[ -z "${trimmed}" || "${trimmed}" == "#"* ]] && continue
    # Top-level section header: "key:" with no value and no leading whitespace
    if [[ "${line}" =~ ^([a-z-]+):$ ]]; then
      section="${BASH_REMATCH[1]}"; continue
    fi
    # List item: "  - value"
    if [[ "${line}" =~ ^[[:space:]]+-[[:space:]]+(.+)$ ]]; then
      value="${BASH_REMATCH[1]}"
      case "${section}" in
        http-domain-whitelist) echo "${value}" >> "${SQUID_WHITELIST}" ;;
        host-ports)            echo "${value}" >> "${HOST_PORTS}" ;;
      esac
      continue
    fi
    # Map entry: "  key: value"
    if [[ "${line}" =~ ^[[:space:]]+([^[:space:]:]+):[[:space:]]+(.+)$ ]]; then
      key="${BASH_REMATCH[1]}"
      value="${BASH_REMATCH[2]}"
      case "${section}" in
        env-passthrough) echo "${key}=${value}" >> "${ENV_PASSTHROUGH}" ;;
        env)             echo "${key}=${value}" >> "${ENV_STATIC}" ;;
      esac
      continue
    fi
  done < "${CONFIG_FILE}"
  echo "  Extracted $(wc -l < "${SQUID_WHITELIST}") whitelisted domain(s) into squid-whitelist.txt"
  echo "  Extracted $(wc -l < "${HOST_PORTS}") host TCP port(s) into host-ports.txt"
  echo "  Extracted $(wc -l < "${ENV_PASSTHROUGH}") env var name(s) into env-passthrough.txt"
  echo "  Extracted $(wc -l < "${ENV_STATIC}") static env var(s) into env.txt"
else
  echo "  Missing required config file: ${CONFIG_FILE}" >&2
  echo "  Create opencode-sandbox-config.yaml (use ocs-init template) and rebuild." >&2
  exit 1
fi



echo "Building Container Image '${SANDBOX_NAME}' (USER_ID=${USER_ID} GROUP_ID=${GROUP_ID})..."
BUILD_LOG="${OPENCODE_SANDBOX_DIR}/docker-build.log"

if "${CONTAINER_RUNTIME}" build \
  --build-arg "USER_ID=${USER_ID}" \
  --build-arg "GROUP_ID=${GROUP_ID}" \
  -t "${SANDBOX_NAME}" \
  -f "${SANDBOX_HOME}/Dockerfile" \
  "${OPENCODE_SANDBOX_DIR}" > "${BUILD_LOG}" 2>&1; then
  echo "✓ Container image '${SANDBOX_NAME}' built successfully"
else
  echo "✗ Container build failed. Output:"
  cat "${BUILD_LOG}"
  exit 1
fi






