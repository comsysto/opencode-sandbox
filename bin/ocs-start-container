#!/usr/bin/env bash
set -euo pipefail

# Source common configuration
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/../shared"

use_sandbox_root
print_sandbox_dir

cleanup() {
  echo
  echo "Stopping Container ${SANDBOX_NAME}..."
  "${CONTAINER_RUNTIME}" stop "${SANDBOX_NAME}" >/dev/null 2>&1 || true
}

trap cleanup INT TERM


if [[ ! -f "${OPENCODE_PASSWORD_FILE}" || ! -f "${MISE_CONFIG_SANDBOX_FILE}" ]]; then
  echo "Missing sandbox build artifacts in ${OPENCODE_SANDBOX_DIR}."
  echo "Run ${SANDBOX_HOME}/bin/ocs-rebuild-container first."
  exit 1
fi

if ! "${CONTAINER_RUNTIME}" image inspect "${SANDBOX_NAME}" >/dev/null 2>&1; then
  echo "Container image ${SANDBOX_NAME} is not available locally."
  echo "Run ${SANDBOX_HOME}/bin/ocs-rebuild-container first."
  exit 1
fi

if "${CONTAINER_RUNTIME}" container inspect "${SANDBOX_NAME}" >/dev/null 2>&1; then
  echo "Resuming existing container ${SANDBOX_NAME}..."
  "${CONTAINER_RUNTIME}" start -ai "${SANDBOX_NAME}"
else
  echo "Creating container ${SANDBOX_NAME}..."
  "${CONTAINER_RUNTIME}" run --init -it --cap-add NET_ADMIN \
    --add-host=host.lima.internal:host-gateway \
    --add-host=host.docker.internal:host-gateway \
    --add-host=host.containers.internal:host-gateway \
    --name "${SANDBOX_NAME}" \
    -p "${LOCALHOST}:${PORT}:4096" \
    -v "${ROOT_DIR}:/workspace" \
    -v "${OPENCODE_STATE_DIR}:/home/dev/.local/share/opencode" \
    "${SANDBOX_NAME}"
fi



