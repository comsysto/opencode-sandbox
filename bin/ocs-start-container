#!/usr/bin/env bash
set -euo pipefail

# Source common configuration
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/../shared"

use_sandbox_root
print_sandbox_dir

cleanup() {
  echo
  echo "Stopping Container ${SANDBOX_NAME}..."
  "${CONTAINER_RUNTIME}" stop "${SANDBOX_NAME}" >/dev/null 2>&1 || true
}

trap cleanup INT TERM


if [[ ! -f "${OPENCODE_PASSWORD_FILE}" || ! -f "${MISE_CONFIG_SANDBOX_FILE}" ]]; then
  echo "Missing sandbox build artifacts in ${OPENCODE_SANDBOX_DIR}."
  echo "Run ${SANDBOX_HOME}/bin/ocs-rebuild-container first."
  exit 1
fi

if ! "${CONTAINER_RUNTIME}" image inspect "${SANDBOX_NAME}" >/dev/null 2>&1; then
  echo "Container image ${SANDBOX_NAME} is not available locally."
  echo "Run ${SANDBOX_HOME}/bin/ocs-rebuild-container first."
  exit 1
fi

echo "Starting container ${SANDBOX_NAME}..."
echo ""

# Build -e flags from env-passthrough.txt (format: CONTAINER_NAME=HOST_NAME)
env_flags=()
env_log=()
ENV_PASSTHROUGH_FILE="${OPENCODE_SANDBOX_DIR}/env-passthrough.txt"
if [[ -f "${ENV_PASSTHROUGH_FILE}" ]]; then
  while IFS= read -r entry || [[ -n "${entry}" ]]; do
    [[ -z "${entry}" ]] && continue
    container_name="${entry%%=*}"
    host_name="${entry#*=}"
    if [[ -n "${!host_name+set}" ]]; then
      env_flags+=(-e "${container_name}=${!host_name}")
      env_log+=("    ${container_name} (from host \$${host_name})")
    else
      env_log+=("    ${container_name} (skipped — \$${host_name} not set on host)")
    fi
  done < "${ENV_PASSTHROUGH_FILE}"
fi

# Build --env KEY=VALUE flags for static env vars from env.txt
ENV_STATIC_FILE="${OPENCODE_SANDBOX_DIR}/env.txt"
if [[ -f "${ENV_STATIC_FILE}" ]]; then
  while IFS= read -r assignment || [[ -n "${assignment}" ]]; do
    [[ -n "${assignment}" ]] && env_flags+=(--env "${assignment}") && env_log+=("    ${assignment} (static)")
  done < "${ENV_STATIC_FILE}"
fi

# Print full config summary before handing off to docker
# shellcheck disable=SC2153  # PORT and LOCALHOST are defined in shared
echo "   sandbox:   ${SANDBOX_NAME}"
# shellcheck disable=SC2153
echo "   url:       http://${LOCALHOST}:${PORT}"
echo "   workspace: ${ROOT_DIR}"
echo ""
echo "   env vars:"
if [[ "${#env_log[@]}" -gt 0 ]]; then
  for entry in "${env_log[@]}"; do echo "${entry}"; done
else
  echo "    (none)"
fi
echo ""
echo "   https domains whitelisted:"
SQUID_WHITELIST="${OPENCODE_SANDBOX_DIR}/squid-whitelist.txt"
if [[ -f "${SQUID_WHITELIST}" ]]; then
  while IFS= read -r domain || [[ -n "${domain}" ]]; do
    echo "     ${domain}"
  done < "${SQUID_WHITELIST}"
fi
echo ""
echo "   host ports:"
HOST_PORTS_FILE="${OPENCODE_SANDBOX_DIR}/host-ports.txt"
if [[ -f "${HOST_PORTS_FILE}" ]]; then
  while IFS= read -r port || [[ -n "${port}" ]]; do
    echo "     docker.host:${port}"
  done < "${HOST_PORTS_FILE}"
  if [[ ! -s "${HOST_PORTS_FILE}" ]]; then
    echo "     (none)"
  fi
fi
echo ""
echo "---"
echo ""

"${CONTAINER_RUNTIME}" run --rm --init -it --cap-add NET_ADMIN \
  --add-host=docker.host:host-gateway \
  --name "${SANDBOX_NAME}" \
  -p "${LOCALHOST}:${PORT}:4096" \
  -v "${ROOT_DIR}:/workspace" \
  -v "${OPENCODE_STATE_DIR}:/home/dev/.local/share/opencode" \
  "${env_flags[@]+"${env_flags[@]}"}" \
  "${SANDBOX_NAME}"



