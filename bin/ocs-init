#!/usr/bin/env bash
set -euo pipefail

# Source common configuration
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=/dev/null
source "${SCRIPT_DIR}/../shared"
# Re-establish SCRIPT_DIR after sourcing shared (shared redefines it for its own location)
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

TARGET_DIR="${1:-$(pwd)}"
TARGET_DIR="$(cd -- "${TARGET_DIR}" && pwd)"

refresh_root_paths "${TARGET_DIR}"

echo "Initializing OpenCode sandbox in: ${TARGET_DIR}"
echo ""

# Ask the user a yes/no question; default is yes (Enter accepts).
confirm() {
  local prompt="${1:?prompt is required}"
  local answer
  while true; do
    printf '%s [Y/n] ' "${prompt}"
    read -r answer
    case "${answer}" in
      [Yy]*|"") return 0 ;;
      [Nn]*)     return 1 ;;
      *)         echo "  Please answer y or n." ;;
    esac
  done
}

# --- mise.toml ---
MISE_FILE="${TARGET_DIR}/mise.toml"
echo "Step 1/4: Write a minimal mise.toml (opencode only) to ${MISE_FILE}."
echo "  This file tells mise which version of opencode to install in the container."
if [[ -f "${MISE_FILE}" ]]; then
  echo "  Already exists — skipping."
else
  if confirm "  Write mise.toml?"; then
    cp "${SANDBOX_HOME}/init-templates/mise.toml" "${MISE_FILE}"
    echo "  ✓ Written."
  else
    echo "  Skipped."
  fi
fi
echo ""

# --- opencode-sandbox-config (required) ---
CONFIG_FILE="${TARGET_DIR}/opencode-sandbox-config.yaml"
CONFIG_TEMPLATE="${SANDBOX_HOME}/init-templates/opencode-sandbox-config.yaml"
echo "Step 2/4: Create ${CONFIG_FILE} from template (required)."
echo "  This file controls outbound proxy access, host port access, and which"
echo "  host environment variables are forwarded into the container."
if [[ -f "${CONFIG_FILE}" ]]; then
  echo "  Already exists — skipping."
else
  if confirm "  Create opencode-sandbox-config.yaml from template?"; then
    cp "${CONFIG_TEMPLATE}" "${CONFIG_FILE}"
    # Inject sandbox-name: use the directory basename as the human-readable project label.
    # Uniqueness across multiple checkouts is handled at runtime via SANDBOX_ID in shared.
    PROJECT_NAME="$(basename "${TARGET_DIR}")"
    # Prepend sandbox-name as the first entry in the config file
    TEMP_FILE="$(mktemp)"
    printf 'sandbox-name: %s\n\n' "${PROJECT_NAME}" > "${TEMP_FILE}"
    cat "${CONFIG_FILE}" >> "${TEMP_FILE}"
    mv "${TEMP_FILE}" "${CONFIG_FILE}"
    echo "  ✓ Created (sandbox-name: ${PROJECT_NAME})."
  else
    echo "  This file is required. Aborting initialization."
    exit 1
  fi
fi
echo ""

# --- opencode.jsonc ---
JSONC_FILE="${TARGET_DIR}/opencode.jsonc"
JSONC_SOURCE="${SANDBOX_HOME}/init-templates/opencode.jsonc"
echo "Step 3/4: Copy opencode.jsonc from the sandbox home to ${JSONC_FILE}."
echo "  This file configures the OpenCode model, provider, and permission policy."
if [[ -f "${JSONC_FILE}" ]]; then
  echo "  Already exists — skipping."
else
  if confirm "  Copy opencode.jsonc?"; then
    cp "${JSONC_SOURCE}" "${JSONC_FILE}"
    echo "  ✓ Copied."
  else
    echo "  Skipped."
  fi
fi
echo ""

# --- opencode-sandbox-pre-start-container.sh ---
HOOK_FILE="${TARGET_DIR}/opencode-sandbox-pre-start-container.sh"
echo "Step 4/4: Create ${HOOK_FILE}."
echo "  This script is sourced by ocs-start-container before the container starts."
echo "  Use it to export env vars at start time (e.g. refresh AWS credentials)."
if [[ -f "${HOOK_FILE}" ]]; then
  echo "  Already exists — skipping."
else
  if confirm "  Create opencode-sandbox-pre-start-container.sh?"; then
    printf '#!/usr/bin/env bash\n# Sourced by ocs-start-container before the container starts.\n# Export environment variables here, e.g. refresh AWS credentials.\n' > "${HOOK_FILE}"
    chmod +x "${HOOK_FILE}"
    echo "  ✓ Created."
  else
    echo "  Skipped."
  fi
fi
echo ""

# --- rebuild the container ---
echo "Step 4/4: Build the Docker container image for this project."
echo "  This compiles the image using the Dockerfile in the sandbox home and"
echo "  copies the mise.toml into the container build context."
if confirm "  Run ocs-rebuild-container?"; then
  cd "${TARGET_DIR}"
  "${SCRIPT_DIR}/ocs-rebuild-container"
else
  echo "  Skipped. Run ocs-rebuild-container manually when ready."
fi
